page {
  background: #f0f4e8;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 160rpx;
}

/* 便签墙瀑布流 */
.board {
  column-count: 2;
  column-gap: 20rpx;
}

.note {
  break-inside: avoid;
  margin-bottom: 20rpx;
  padding: 28rpx 24rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  transform: rotate(var(--rotate, 0deg));
}

.note:nth-child(odd) {
  --rotate: -1deg;
}

.note:nth-child(even) {
  --rotate: 1deg;
}

.note:nth-child(3n) {
  --rotate: 0.5deg;
}

.note--yellow {
  background: #fff9c4;
}

.note--green {
  background: #c8e6c9;
}

.note--blue {
  background: #bbdefb;
}

.note--pink {
  background: #f8bbd0;
}

.note--purple {
  background: #e1bee7;
}

.note--orange {
  background: #ffe0b2;
}

.note__content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
  word-break: break-all;
}

.note__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.note__author {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.note__avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.note__name {
  font-size: 22rpx;
  color: #666;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note__time {
  font-size: 20rpx;
  color: #999;
}

/* 发布 FAB 按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #43a047;
  box-shadow: 0 8rpx 24rpx rgba(67, 160, 71, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  font-size: 48rpx;
}

.fab-btn:active {
  transform: scale(0.92);
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: #bbb;
}

/* 弹窗遮罩 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

/* 发布弹窗 */
.post-popup {
  width: 100%;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
}

.post-popup__title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.post-popup__input {
  width: 100%;
  height: 240rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.post-popup__count {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.post-popup__colors {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 32rpx;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: border-color 0.2s;
}

.color-dot--active {
  border-color: #333;
}

.color-dot--yellow {
  background: #fff9c4;
}

.color-dot--green {
  background: #c8e6c9;
}

.color-dot--blue {
  background: #bbdefb;
}

.color-dot--pink {
  background: #f8bbd0;
}

.color-dot--purple {
  background: #e1bee7;
}

.color-dot--orange {
  background: #ffe0b2;
}

.post-popup__actions {
  display: flex;
  gap: 24rpx;
}

.post-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  border: none;
}

.post-btn--cancel {
  background: #f5f5f5;
  color: #666;
}

.post-btn--confirm {
  background: #43a047;
  color: #fff;
}
