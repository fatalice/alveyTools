<view class="page">
  <!-- 便签墙 -->
  <view class="board" wx:if="{{messages.length > 0}}">
    <view
      class="note note--{{item.color}}"
      wx:for="{{messages}}"
      wx:key="_id"
    >
      <view class="note__content">{{item.content}}</view>
      <view class="note__footer">
        <view class="note__author">
          <image class="note__avatar" src="{{item.avatar || '/images/icons/avatar.png'}}" mode="aspectFill" />
          <text class="note__name">{{item.nickname || '匿名'}}</text>
        </view>
        <text class="note__time">{{item.timeText}}</text>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text>还没有留言，来写第一条吧~</text>
  </view>

  <!-- 发布按钮 -->
  <view class="fab-btn" bindtap="onShowPost">✏️</view>
</view>

<!-- 发布弹窗（原生实现） -->
<view class="popup-mask" wx:if="{{postVisible}}" bindtap="onCancelPost">
  <view class="post-popup" catchtap>
    <view class="post-popup__title">写一条留言</view>
    <textarea
      class="post-popup__input"
      placeholder="写下你想说的话..."
      maxlength="200"
      value="{{postContent}}"
      bindinput="onPostInput"
      auto-focus
    />
    <view class="post-popup__count">{{postContent.length}}/200</view>
    <view class="post-popup__colors">
      <view
        class="color-dot color-dot--{{item}} {{postColor === item ? 'color-dot--active' : ''}}"
        wx:for="{{colorOptions}}"
        wx:key="*this"
        data-color="{{item}}"
        bindtap="onPickColor"
      />
    </view>
    <view class="post-popup__actions">
      <button class="post-btn post-btn--cancel" bindtap="onCancelPost">取消</button>
      <button class="post-btn post-btn--confirm" bindtap="onSubmitPost" loading="{{submitting}}">发布</button>
    </view>
  </view>
</view>
