page { background: #f5f6fa; }

.page { padding: 32rpx; min-height: 100vh; }

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  background: #e6f7ff;
  color: #1890ff;
}

.action-delete { background: #fff1f0; color: #fa5151; }

.header-card, .content-card, .images-card, .mood-card, .time-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.detail-label { font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.detail-time { font-size: 32rpx; color: #333; font-weight: 500; margin-bottom: 16rpx; }
.detail-mood { font-size: 36rpx; }

.detail-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

.img-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.detail-img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
}

.footer-info {
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 40rpx;
}
