<view class="page">
  <!-- 发生时间 -->
  <view class="section">
    <view class="section-title">发生时间 *</view>
    <view class="time-row">
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="time-btn">{{date}}</view>
      </picker>
      <picker mode="time" value="{{time}}" bindchange="onTimeChange">
        <view class="time-btn">{{time}}</view>
      </picker>
    </view>
  </view>

  <!-- 心情 -->
  <view class="section">
    <view class="section-title">心情 *</view>
    <view class="mood-grid">
      <view class="mood-item {{mood === item.key ? 'mood-active' : ''}}" wx:for="{{moods}}" wx:key="key" data-key="{{item.key}}" bindtap="onMoodTap">
        <text class="mood-emoji">{{item.emoji}}</text>
        <text class="mood-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 文字 -->
  <view class="section">
    <view class="section-title">文字记录</view>
    <textarea class="content-input" placeholder="记录今天的牙套故事..." maxlength="500" value="{{content}}" bindinput="onContentInput" />
    <view class="char-count">{{content.length}}/500</view>
  </view>

  <!-- 图片 -->
  <view class="section">
    <view class="section-title">照片</view>
    <view class="img-grid">
      <view class="img-item" wx:for="{{images}}" wx:key="url">
        <image class="img-thumb" src="{{item.url}}" mode="aspectFill" />
        <view class="img-remove" data-idx="{{index}}" bindtap="onRemoveImage">×</view>
      </view>
      <view class="img-add" wx:if="{{images.length < 9}}" bindtap="onChooseImage">
        <text class="img-add-icon">+</text>
        <text class="img-add-text">{{images.length}}/9</text>
      </view>
    </view>
  </view>

  <!-- 提交 -->
  <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
    {{id ? '保存修改' : '发布记录'}}
  </view>
</view>
