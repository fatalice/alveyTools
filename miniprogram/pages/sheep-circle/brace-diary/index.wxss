page { background: #f5f6fa; }

.page { padding: 24rpx 32rpx 160rpx; min-height: 100vh; }

.fab {
  position: fixed;
  right: 48rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
  z-index: 99;
}

.fab-icon { font-size: 52rpx; color: #fff; font-weight: 300; }

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: #999;
}

.empty-emoji { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; margin-bottom: 40rpx; }
.empty-btn {
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
}

/* 时间轴 */
.timeline {
  padding-left: 40rpx;
  border-left: 4rpx solid #e0e0e0;
  margin-left: 20rpx;
}

.timeline-item {
  position: relative;
  margin-bottom: 32rpx;
}

.tl-dot {
  position: absolute;
  left: -52rpx;
  top: 28rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #07c160;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 4rpx #e0e0e0;
}

.tl-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tl-card:active { background: #fafafa; }

.tl-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.tl-mood {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.tl-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tl-img-hint {
  font-size: 24rpx;
  color: #1890ff;
}

.tl-no-img { color: #ccc; }
