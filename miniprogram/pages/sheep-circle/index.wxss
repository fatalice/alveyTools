page {
  background: #f5f6fa;
}

.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.header {
  background: linear-gradient(135deg, #d81b60 0%, #e91e63 40%, #f48fb1 100%);
  padding: 80rpx 40rpx 100rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.header-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  position: relative;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  position: relative;
}

.grid-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 32rpx;
  margin-top: -40rpx;
}

.feature-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.15s;
}

.feature-card:active {
  transform: scale(0.96);
}

.feature-card__icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-card--green .feature-card__icon {
  background: #e8f5e9;
}

.feature-card--blue .feature-card__icon {
  background: #e3f2fd;
}

.feature-card--orange .feature-card__icon {
  background: #fff3e0;
}

.feature-card--pink .feature-card__icon {
  background: #fce4ec;
}

.feature-card--purple .feature-card__icon {
  background: #f3e5f5;
}

.feature-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-card__desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}
