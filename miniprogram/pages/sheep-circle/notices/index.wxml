<view class="page">
  <view class="notice-list" wx:if="{{notices.length > 0}}">
    <view class="notice-card {{item.pinned ? 'notice-card--pinned' : ''}}" wx:for="{{notices}}" wx:key="_id">
      <view class="notice-card__header">
        <text class="notice-card__pin" wx:if="{{item.pinned}}">📌 置顶</text>
        <text class="notice-card__title">{{item.title}}</text>
      </view>
      <view class="notice-card__content">{{item.content}}</view>
      <view class="notice-card__time">{{item.timeText}}</view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text>暂无公告</text>
  </view>
</view>
