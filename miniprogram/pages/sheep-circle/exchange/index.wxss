page {
  background: #f5f6fa;
}

.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.balance-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 32rpx;
  padding: 32rpx 40rpx;
  background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(67, 160, 71, 0.2);
}

.balance-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.balance-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.prize-list {
  margin: 0 32rpx;
}

.prize-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.prize-card__icon {
  font-size: 56rpx;
  width: 96rpx;
  height: 96rpx;
  background: #fff3e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.prize-card__info {
  flex: 1;
}

.prize-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.prize-card__cost {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.prize-card__cost-text {
  font-size: 26rpx;
  color: #ff9800;
  font-weight: 500;
}

.exchange-records {
  margin: 40rpx 32rpx 0;
}

.records-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.record-item__left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-item__name {
  font-size: 28rpx;
  color: #333;
}

.record-item__time {
  font-size: 22rpx;
  color: #bbb;
}

.record-item__cost {
  font-size: 32rpx;
  font-weight: 600;
  color: #f44336;
}
