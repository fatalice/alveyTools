page {
  background: #f5f6fa;
}

.page {
  min-height: 100vh;
}

.hero {
  background: linear-gradient(135deg, #1aad19 0%, #43a047 50%, #66bb6a 100%);
  padding: 80rpx 48rpx 100rpx;
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.grid {
  margin: -40rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.12s;
}

.card:active {
  transform: scale(0.98);
}

.card__emoji {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.card--0 .card__emoji {
  background: #e8f5e9;
}

.card--1 .card__emoji {
  background: #e3f2fd;
}

.card--2 .card__emoji {
  background: #fff3e0;
}

.card--3 .card__emoji {
  background: #fce4ec;
}

.card__body {
  flex: 1;
}

.card__name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}

.card__desc {
  font-size: 24rpx;
  color: #999;
}

.card__arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 16rpx;
}
