<!--index.wxml-->
<view class="page">
  <view class="hero">
    <view class="hero-title">alveyTools</view>
    <view class="hero-desc">工具与学习平台</view>
  </view>

  <view class="grid">
    <view
      class="card card--{{index}}"
      wx:for="{{gridItems}}"
      wx:key="name"
      data-index="{{index}}"
      bindtap="onGridTap"
    >
      <view class="card__emoji">{{item.icon}}</view>
      <view class="card__body">
        <view class="card__name">{{item.name}}</view>
        <view class="card__desc">{{item.desc}}</view>
      </view>
      <view class="card__arrow">›</view>
    </view>
  </view>
</view>
