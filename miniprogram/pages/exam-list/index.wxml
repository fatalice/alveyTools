<!--pages/exam-list/index.wxml-->
<view class="page">
  <view class="filter-bar">
    <text class="filter-icon">🔍</text>
    <text class="filter-text">筛选：全部</text>
  </view>

  <view class="exam-card" wx:for="{{examList}}" wx:key="id" data-id="{{item.id}}" bindtap="onExamTap">
    <view class="card-header">
      <view class="card-icon-wrap" style="background-color: {{item.color}}">
        <text class="card-icon">{{item.icon}}</text>
      </view>
      <view class="card-info">
        <view class="card-title">{{item.title}}</view>
        <view class="card-subtitle">{{item.subtitle}}</view>
      </view>
      <view class="card-status" wx:if="{{item.status}}">{{item.status}}</view>
    </view>
    <view class="card-footer">
      <text class="card-meta" wx:if="{{item.totalScore}}">总分{{item.totalScore}}分</text>
      <text class="card-meta">共{{item.questionCount}}{{item.id === 'ai-trainer-practice' ? '个文件' : '道题'}}</text>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{examList.length <= 2}}">
    <text>更多考试科目即将上线...</text>
  </view>
</view>
