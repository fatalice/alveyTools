/* pages/exam-list/index.wxss */
page {
  background-color: #f5f6fa;
}

.page {
  padding: 24rpx 32rpx;
  min-height: 100vh;
}

.filter-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0 32rpx;
}

.filter-icon {
  font-size: 32rpx;
}

.filter-text {
  font-size: 28rpx;
  color: #666;
}

.exam-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.exam-card:active {
  transform: scale(0.98);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-icon {
  font-size: 40rpx;
}

.card-info {
  flex: 1;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #999;
}

.card-status {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.card-footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 32rpx;
}

.card-meta {
  font-size: 26rpx;
  color: #888;
}

.empty-tip {
  text-align: center;
  margin-top: 64rpx;
  font-size: 26rpx;
  color: #bbb;
}
