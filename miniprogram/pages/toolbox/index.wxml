<view class="page">
  <view class="header">
    <text class="header-title">工具箱</text>
    <text class="header-desc">实用小工具合集</text>
  </view>

  <view class="tool-list">
    <view class="tool-card" wx:for="{{tools}}" wx:key="id" data-id="{{item.id}}" bindtap="onToolTap">
      <view class="tool-icon-wrap" style="background: {{item.color}}">
        <text class="tool-icon">{{item.icon}}</text>
      </view>
      <view class="tool-info">
        <text class="tool-name">{{item.name}}</text>
        <text class="tool-desc">{{item.desc}}</text>
      </view>
      <text class="tool-arrow">›</text>
    </view>
  </view>
</view>
