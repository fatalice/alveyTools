/**pages/toolbox/index.wxss**/

page {
  background-color: #f6f6f6;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.grid-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 48rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.grid-item:active {
  background-color: #f0f0f0;
}

.grid-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.grid-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
