page { background: #f5f6fa; }

.page { padding: 32rpx; min-height: 100vh; }

.header { padding: 20rpx 0 40rpx; }
.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}
.header-desc { font-size: 26rpx; color: #999; }

.tool-list { display: flex; flex-direction: column; gap: 20rpx; }

.tool-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.tool-card:active { transform: scale(0.98); }

.tool-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tool-icon { font-size: 48rpx; }

.tool-info { flex: 1; margin-left: 28rpx; }
.tool-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}
.tool-desc { font-size: 24rpx; color: #999; }

.tool-arrow { font-size: 40rpx; color: #ccc; flex-shrink: 0; }
