<view class="page">
  <!-- 顶部刷新区 -->
  <view class="refresh-bar">
    <view class="update-info">
      <text class="update-label" wx:if="{{updateTime}}">更新于 {{updateTime}}</text>
      <text class="update-label" wx:else>暂无数据，请点击刷新</text>
    </view>
    <view class="refresh-btn {{loading ? 'loading' : ''}}" bindtap="onRefresh">
      <text>{{loading ? '获取中...' : '🔄 刷新汇率'}}</text>
    </view>
  </view>

  <!-- 基准货币选择 -->
  <view class="section">
    <view class="section-title">选择基准货币</view>
    <view class="currency-tabs">
      <view class="tab {{baseCurrency === item.code ? 'tab-active' : ''}}" wx:for="{{currencies}}" wx:key="code" data-code="{{item.code}}" bindtap="onBaseTap">
        <text class="tab-flag">{{item.flag}}</text>
        <text class="tab-code">{{item.code}}</text>
      </view>
    </view>
  </view>

  <!-- 金额输入 -->
  <view class="section">
    <view class="amount-row">
      <text class="amount-label">{{baseCurrency}}</text>
      <input class="amount-input" type="digit" value="{{baseAmount}}" bindinput="onAmountInput" placeholder="输入金额" />
    </view>
  </view>

  <!-- 汇率结果 -->
  <view class="section" wx:if="{{results.length > 0}}">
    <view class="section-title">兑换结果</view>
    <view class="result-list">
      <view class="result-item" wx:for="{{results}}" wx:key="code">
        <view class="result-left">
          <text class="result-flag">{{item.flag}}</text>
          <view class="result-info">
            <text class="result-name">{{item.name}}</text>
            <text class="result-rate">1 {{baseCurrency}} = {{item.rate}} {{item.code}}</text>
          </view>
        </view>
        <view class="result-value">{{item.converted}}</view>
      </view>
    </view>
  </view>

  <!-- 无数据提示 -->
  <view class="empty" wx:if="{{results.length === 0 && !loading}}">
    <text class="empty-text">请先点击刷新按钮获取今日汇率</text>
  </view>
</view>
