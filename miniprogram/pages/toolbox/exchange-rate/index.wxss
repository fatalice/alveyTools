page { background: #f5f6fa; }

.page { padding: 32rpx; min-height: 100vh; }

/* 刷新栏 */
.refresh-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.update-label { font-size: 24rpx; color: #999; }

.refresh-btn {
  background: #07c160;
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  font-weight: 500;
}

.refresh-btn:active { opacity: 0.85; }
.refresh-btn.loading { opacity: 0.6; }

/* 区块 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.section-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* 货币选择 */
.currency-tabs { display: flex; gap: 16rpx; flex-wrap: wrap; }
.tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  background: #fafafa;
}
.tab:active { background: #f0f0f0; }
.tab-active { border-color: #07c160; background: #e8f8ef; }
.tab-flag { font-size: 32rpx; }
.tab-code { font-size: 26rpx; color: #333; font-weight: 500; }
.tab-active .tab-code { color: #07c160; }

/* 金额输入 */
.amount-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.amount-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #07c160;
  min-width: 80rpx;
}
.amount-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a2e;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #eee;
}

/* 结果列表 */
.result-list { display: flex; flex-direction: column; gap: 24rpx; }
.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.result-item:last-child { border-bottom: none; }

.result-left { display: flex; align-items: center; gap: 16rpx; }
.result-flag { font-size: 40rpx; }
.result-info { display: flex; flex-direction: column; }
.result-name { font-size: 28rpx; color: #333; font-weight: 500; }
.result-rate { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.result-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* 空态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
}
.empty-text { font-size: 28rpx; color: #999; }
