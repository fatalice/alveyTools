page {
  background-color: #f5f6fa;
}

.page {
  padding: 24rpx 32rpx;
  min-height: 100vh;
}

.header {
  padding: 32rpx 0 40rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.notebook-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f8f8f8;
}

.notebook-item:last-child {
  border-bottom: none;
}

.notebook-item:active {
  background: #f5f5f5;
}

.nb-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.nb-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.nb-arrow {
  font-size: 36rpx;
  color: #ccc;
}
