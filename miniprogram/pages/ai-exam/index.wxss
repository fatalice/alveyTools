/** pages/ai-exam/index.wxss */
page {
  background: #f6f6f6;
}

.page {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 32rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #111;
}

.hero-sub {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.hero-refresh {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #576b95;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.stat-num.ok {
  color: #07c160;
}

.stat-num.bad {
  color: #fa5151;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.type-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.type-item {
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  text-align: center;
}

.type-item.active {
  border-color: #07c160;
  background: #f0fff4;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.type-count {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333;
}

.primary-btn {
  background: #07c160;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  margin-top: 16rpx;
}

.ghost-btn {
  background: #fff;
  color: #333;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.practice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.back-link {
  font-size: 28rpx;
  color: #576b95;
}

.progress-text {
  font-size: 28rpx;
  color: #666;
}

.progress-bar {
  height: 8rpx;
  background: #e5e5e5;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-fill {
  height: 100%;
  background: #07c160;
  transition: width 0.2s;
}

.question-card {
  margin-bottom: 24rpx;
}

.q-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.q-tag {
  background: #eef7ff;
  color: #1485ee;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.q-id {
  font-size: 24rpx;
  color: #999;
}

.q-text {
  font-size: 32rpx;
  line-height: 1.7;
  color: #222;
  margin-bottom: 28rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  background: #fafafa;
}

.option.selected {
  border-color: #07c160;
  background: #f0fff4;
}

.option.correct {
  border-color: #07c160;
  background: #eaffef;
}

.option.wrong {
  border-color: #fa5151;
  background: #fff0f0;
}

.option-key {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #ddd;
  font-size: 24rpx;
  flex-shrink: 0;
}

.option-label {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.result-box {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.result-box.ok {
  background: #eaffef;
}

.result-box.bad {
  background: #fff0f0;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.result-explain {
  font-size: 26rpx;
  line-height: 1.7;
  color: #555;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.action-row .ghost-btn,
.action-row .primary-btn {
  flex: 1;
  margin-top: 0;
}

.flex-btn {
  flex: 2;
}

.finish-card {
  text-align: center;
  padding: 64rpx 32rpx;
}

.finish-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111;
}

.finish-score {
  margin-top: 24rpx;
  font-size: 34rpx;
  color: #333;
}

.finish-rate {
  margin: 12rpx 0 32rpx;
  font-size: 28rpx;
  color: #07c160;
}
