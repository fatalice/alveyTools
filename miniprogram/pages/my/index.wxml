<t-navbar title="我的" fixed placeholder />

<view class="page">
  <!-- 顶部个人信息卡片 -->
  <view class="header-card">
    <!-- 已登录 -->
    <view class="profile" wx:if="{{isLoggedIn}}">
      <t-avatar image="{{userInfo.image || userInfo.avatarFileID}}" size="128rpx" shape="circle" />
      <view class="profile-info">
        <view class="profile-name">{{userInfo.name || '用户'}}</view>
        <view class="profile-tags">
          <t-tag wx:if="{{userInfo.city}}" variant="light" size="small" theme="success" icon="location">{{userInfo.city}}</t-tag>
        </view>
      </view>
      <view class="profile-score">
        <view class="profile-score__value">{{totalScore}}</view>
        <view class="profile-score__label">积分</view>
      </view>
    </view>
    <!-- 未登录 -->
    <view class="profile" wx:else bindtap="onLogin">
      <t-avatar icon="user" size="128rpx" shape="circle" />
      <view class="profile-info">
        <view class="profile-name">点击登录</view>
        <view class="profile-desc">选择头像、填写昵称即可</view>
      </view>
      <t-icon name="chevron-right" size="40rpx" color="#bbb" />
    </view>
  </view>

  <!-- 三栏统计 -->
  <view class="stats-card" wx:if="{{isLoggedIn}}">
    <view class="stats-item" bindtap="onToggleRecords">
      <view class="stats-value">{{scoreRecords.length}}</view>
      <view class="stats-label">计分明细</view>
    </view>
    <view class="stats-item">
      <view class="stats-value">{{learningDays}}</view>
      <view class="stats-label">学习天数</view>
    </view>
    <view class="stats-item" bindtap="onCheckin">
      <view class="stats-value">
        <t-icon name="check" size="36rpx" />
      </view>
      <view class="stats-label">签到 +1</view>
    </view>
  </view>

  <!-- 计分明细展开 -->
  <view class="records-card" wx:if="{{isLoggedIn && showRecords}}">
    <view class="records-card__title">计分明细</view>
    <view class="score-record" wx:for="{{scoreRecords}}" wx:key="_id">
      <view class="score-record__left">
        <text class="score-record__desc">{{item.desc}}</text>
        <text class="score-record__time">{{item.timeText}}</text>
      </view>
      <text class="score-record__points">+{{item.points}}</text>
    </view>
    <view class="score-record--empty" wx:if="{{scoreRecords.length === 0}}">
      <text>暂无记录，签到可获得积分</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="section-card">
    <t-cell-group bordered="{{false}}">
      <t-cell
        wx:for="{{settingList}}"
        wx:key="type"
        title="{{item.name}}"
        leftIcon="{{item.icon}}"
        hover
        arrow
        data-item="{{item}}"
        bindclick="onSettingClick"
      >
        <t-badge wx:if="{{item.badge}}" slot="note" dot />
      </t-cell>
      <t-cell
        wx:if="{{isLoggedIn}}"
        title="退出登录"
        leftIcon="poweroff"
        hover
        bindclick="onLogout"
      />
    </t-cell-group>
  </view>
</view>

<!-- 登录弹窗 -->
<t-popup visible="{{loginVisible}}" placement="bottom" bind:visible-change="onLoginPopupChange">
  <view class="login-popup">
    <view class="login-popup__title">设置头像和昵称</view>
    <view class="login-popup__avatar-row">
      <button class="login-popup__avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <t-avatar wx:if="{{pendingAvatar}}" image="{{pendingAvatar}}" size="160rpx" shape="circle" />
        <t-avatar wx:else icon="user" size="160rpx" shape="circle" />
        <view class="login-popup__avatar-tip">点击选择头像</view>
      </button>
    </view>
    <view class="login-popup__nick-row">
      <view class="login-popup__nick-label">昵称</view>
      <input
        class="login-popup__nick-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{pendingNickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameInput"
      />
    </view>
    <view class="login-popup__actions">
      <t-button theme="default" size="large" block bindtap="onLoginClose">取消</t-button>
      <t-button theme="primary" size="large" block bindtap="onConfirmLogin" loading="{{submitting}}">确定</t-button>
    </view>
  </view>
</t-popup>
