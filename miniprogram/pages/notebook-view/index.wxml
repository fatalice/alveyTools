<view class="page">
  <view class="cell-card" wx:for="{{cells}}" wx:key="index">
    <view class="cell-header">
      <text class="cell-type {{item.type === 'code' ? 'type-code' : 'type-md'}}">{{item.type === 'code' ? 'Code' : 'Markdown'}}</text>
      <text class="cell-index">[{{index + 1}}]</text>
    </view>
    <scroll-view scroll-x class="cell-body-scroll">
      <view class="cell-body">
        <text class="cell-source" user-select>{{item.source}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="empty" wx:if="{{cells.length === 0}}">
    <text>暂无内容</text>
  </view>
</view>
